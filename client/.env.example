VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend URL for production (Vercel -> Railway)
# Example: https://truco-backend-production.up.railway.app
VITE_SERVER_URL=

# Socket transport tuning
# Recommended in web deploy: polling,websocket
VITE_SOCKET_TRANSPORTS=
# 1 to allow upgrade from polling -> websocket
VITE_SOCKET_UPGRADE=0

# Optional voice debug logs in browser console
VITE_VOICE_DEBUG=false

# Optional TURN/STUN for WebRTC voice
VITE_WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
VITE_WEBRTC_TURN_URLS=
VITE_WEBRTC_TURN_USERNAME=
VITE_WEBRTC_TURN_CREDENTIAL=
